    "what": {
      "title": "什么是中转站检测，为什么要查",
      "intro": "中转站（API 中转）把你的请求转发到上游大模型，价格往往比官方便宜不少。但便宜背后可能藏着四类问题，光看商家宣传看不出来：",
      "items": [
        {
          "t": "不可用",
          "d": "掉线、超时、被限流——付了钱却用不了，或时好时坏。"
        },
        {
          "t": "模型掉包 / 降级",
          "d": "你点的是 opus，后台偷偷给你换成更便宜的 haiku 或不知名模型。"
        },
        {
          "t": "假流式",
          "d": "看着像逐字流式输出，其实是攒齐了一次性吐，甚至中途截断。"
        },
        {
          "t": "后端漂移",
          "d": "知识截止日期、行为指纹对不上官方，说明上游被悄悄换掉了。"
        }
      ]
    },
    "how": {
      "title": "RelayPulse 怎么检测：两层信号",
      "intro": "我们不替你下「谁是骗子」的结论，只提供两类客观、可复现的信号，让你自己判断：",
      "availability": {
        "t": "可用性监测",
        "d": "每分钟探测各通道的连通性、延迟和限流，画成时间线热力图。这是 RelayPulse 的老本行——最早的一批中转可用性监测站。"
      },
      "quality": {
        "t": "质量盲测（指纹取证）",
        "d": "在不告诉模型「你是谁」的前提下，用同一组探针同时打官方基线和各中转站，比对响应指纹：数字计数体量判档位（haiku / sonnet / opus）、知识截止探针、思维链体量、流式传输粒度。指纹偏离基线越大，越可能不是它声称的那个模型。"
      },
      "note": "方法是公开、可复现的——这正是我们和「拿广告费排座次」的导航站的根本区别。"
    },
    "ranking": {
      "title": "实时质量排行",
      "intro": "下面是各中转站当前的指纹质量分（0–100，越高越接近官方基线），按分数从高到低排列，赞助与否不影响排序。",
      "disclaimer": "这是「指纹质量分」，衡量「像不像官方模型」，不是综合性能榜——延迟、成功率请进各家详情查看。点「看证据」可查逐次取证记录。",
      "col": {
        "provider": "服务商",
        "channel": "通道",
        "score": "质量分",
        "uptime": "可用率",
        "evidence": "证据",
        "evidenceLink": "看证据"
      },
      "loading": "正在加载实时质量数据…",
      "empty": "暂无质量分数据（rpdiag 集成未启用或尚无盲测结果）。"
    },
    "tactics": {
      "title": "常见掺水手法",
      "intro": "了解这些手法，能帮你看懂质量分背后发生了什么。我们只讲机制，不点名——具体哪家、哪次，请到对应通道详情页看逐次证据：",
      "items": [
        {
          "name": "模型伪装 / 掉包",
          "how": "把 opus、sonnet 的请求路由到更便宜的模型。怎么查：让模型做高难度推理、数字密集任务，对比官方基线的指纹体量。"
        },
        {
          "name": "假流式",
          "how": "非真流式：先攒后吐，或中途截断。怎么查：看流式分块的时间分布与粒度是否和官方一致。"
        },
        {
          "name": "偷偷降级",
          "how": "高峰期把高级模型换成低级模型，平峰再换回来。怎么查：长期盲测，看质量分是否随时段规律波动。"
        },
        {
          "name": "后端漂移",
          "how": "换了上游供应商，导致知识截止、行为变化。怎么查：知识截止探针 + 身份 / 行为指纹比对。"
        }
      ],
      "evidenceNote": "每一类的具体实测证据，都在对应通道的详情页里逐次可查，公开可复现。"
    },
    "diy": {
      "title": "怎么自己检测一个中转站",
      "steps": [
        "看可用性时间线：稳不稳、有没有规律性掉线或限流。",
        "看指纹质量分：像不像官方模型，分数是否长期偏低。",
        "看逐次证据：进详情页，看每一次盲测差在哪个维度。"
      ],
      "cta": "提交一个中转站盲测",
      "ctaDesc": "想测一个还没收录的中转站？提交给我们，纳入盲测序列。"
    },
    "faq": {
      "title": "常见问题",
      "items": [
        {
          "q": "中转站掺水怎么看出来？",
          "a": "看两层信号：可用性时间线（稳不稳）和指纹质量分（像不像官方）。质量分长期明显低于官方基线、或随时段规律波动，往往是降级或掉包的信号；进详情页可看逐次证据。"
        },
        {
          "q": "质量分低就一定是假的吗？",
          "a": "不一定。分低可能是上游本身不稳、被限流、或确实降级。我们只给客观的指纹相似度分，不下「真 / 假」定论——证据逐条公开，结论由你自己判断。"
        },
        {
          "q": "哪个中转站检测网站准？",
          "a": "看三点：方法是否公开可复现、数据是否可溯源、排序是否被广告费影响。只给结论不给证据、或按返佣排座次的，参考价值有限。"
        },
        {
          "q": "中转站可用性怎么查？",
          "a": "RelayPulse 每分钟探测各通道连通性、延迟和限流，画成时间线热力图，可按 90 分钟 / 24 小时 / 7 天 / 30 天查看历史稳定性。"
        },
        {
          "q": "你们和导航站、排行榜有什么不同？",
          "a": "RelayPulse 靠服务商赞助运营，但赞助不影响检测结果与质量排序；探测方法和数据公开、可复现。我们是中立的质量与可用性仪表，不是返佣导航。"
        }
      ]
    }
