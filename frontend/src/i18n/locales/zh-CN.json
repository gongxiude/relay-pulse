  "detect": {
    "meta": {
      "title": "检测方法 - RelayPulse 如何评估 API 中转质量",
      "description": "RelayPulse 检测方法说明：展示当前启用的检测维度、权重、样本覆盖和质量分计算边界，帮助用户理解 API 中转站的可用性与模型指纹评分。"
    },
    "nav": {
      "home": "返回首页"
    },
    "hero": {
      "h1": "RelayPulse 如何检测 API 中转质量",
      "lead": "这个页面说明当前检测方法、启用维度和质量分边界。RelayPulse 同时观察通道可用性和模型指纹相似度，用可复现的探针结果帮助你判断中转站是否稳定、是否接近其声明的模型。"
    },
    "what": {
      "title": "检测要回答什么问题",
      "intro": "API 中转站会把请求转发到上游模型。RelayPulse 的检测不替商家背书，也不只看价格，而是把用户最关心的问题拆成可观察的信号：",
      "items": [
        {
          "t": "能不能稳定用",
          "d": "持续观察连通性、超时、限流和延迟，判断通道是否长期可用。"
        },
        {
          "t": "像不像声明的模型",
          "d": "把候选通道和官方基线放在同一组探针下比较，观察身份、知识、输出体量和协议表面。"
        },
        {
          "t": "协议表面是否正常",
          "d": "检查响应 ID、请求 ID、stop reason、流式分块、usage 和缓存字段是否接近原生上游。"
        },
        {
          "t": "哪些结论暂不能启用",
          "d": "需要跨时间窗口或跨模型档位聚合的维度会标为“已实现未启用”，避免用单次探针下过度结论。"
        }
      ]
    },
    "how": {
      "title": "检测信号分两层",
      "intro": "页面上的质量判断来自两类信号。它们解决的问题不同，也会分别影响你对通道的选择：",
      "availability": {
        "t": "可用性监测",
        "d": "按固定间隔探测通道连通性、延迟、限流和错误类型，形成可用率与时间线。这个信号回答“能不能稳定请求”。"
      },
      "quality": {
        "t": "模型指纹评分",
        "d": "对官方基线和候选通道执行同一组 quick-probe，比较模型身份、知识答案、thinking 信号、缓存字段、响应 ID、流式分块和请求体形态。这个信号回答“像不像声明的模型”。"
      },
      "note": "质量分不是人工投票，也不是赞助排序；它来自当前启用维度的加权结果。未启用维度会展示出来，但不会计入有效权重。"
    },
    "ranking": {
      "title": "当前质量分排行",
      "intro": "下面展示已接入指纹评分的通道，分数越高表示当前响应越接近官方基线。排序只看质量分，赞助状态不参与排序。",
      "disclaimer": "质量分衡量模型指纹相似度，不等于综合购买建议。稳定性、延迟和错误率需要结合服务商详情页一起看。",
      "col": {
        "provider": "服务商",
        "channel": "通道",
        "score": "质量分",
        "uptime": "可用率",
        "evidence": "证据",
        "evidenceLink": "看证据"
      },
      "loading": "正在加载实时质量数据…",
      "empty": "暂无质量分数据（rpdiag 集成未启用或尚无盲测结果）。"
    },
    "tactics": {
      "title": "常见异常模式",
      "intro": "下面这些模式会让质量分下降。它们不直接等于定罪结论，但能帮助你理解某个维度为什么异常：",
      "items": [
        {
          "name": "模型不匹配",
          "how": "请求高阶模型时，响应身份、知识、输出体量或 thinking 信号更像另一个模型档位。"
        },
        {
          "name": "流式异常",
          "how": "响应看似流式，但分块数量、可见文本跨度或结束方式明显偏离官方基线。"
        },
        {
          "name": "缓存与上下文异常",
          "how": "同会话上下文无法连续，或 usage 中缓存读写字段与官方表现差异过大。"
        },
        {
          "name": "协议表面漂移",
          "how": "响应 ID、请求 ID、service tier、geo trace、SDK 标记等协议字段缺失或格式不一致。"
        }
      ],
      "evidenceNote": "这些异常只作为维度解释。实际判断应结合详情页里的通道状态、模型状态和最近检测状态。"
    },
    "diy": {
      "title": "怎么解读一个通道",
      "steps": [
        "先看可用性：通道是否持续可请求，延迟和错误是否稳定。",
        "再看模型状态：目标模型是否启用，最近检测状态是否正常。",
        "最后看质量分：分数是否接近官方基线，异常维度集中在哪一类。"
      ],
      "cta": "提交一个中转站盲测",
      "ctaDesc": "想测一个还没收录的中转站？提交给我们，纳入盲测序列。"
    },
    "faq": {
      "title": "常见问题",
      "items": [
        {
          "q": "中转站掺水怎么看出来？",
          "a": "先看可用性，再看模型指纹。可用性解决稳定性问题，指纹质量分解决“像不像声明模型”的问题。质量分长期明显偏离官方基线时，需要进一步看具体异常维度。"
        },
        {
          "q": "质量分低就一定是假的吗？",
          "a": "不一定。低分可能来自上游不稳定、限流、模板不兼容、响应字段缺失，也可能是真实降级。RelayPulse 给出维度化信号，不把单次分数包装成最终裁决。"
        },
        {
          "q": "哪个中转站检测网站准？",
          "a": "看三点：方法是否公开、维度是否能解释、排序是否受商业因素影响。只给结论但不说明维度和权重的排行，参考价值有限。"
        },
        {
          "q": "中转站可用性怎么查？",
          "a": "RelayPulse 每分钟探测各通道连通性、延迟和限流，画成时间线热力图，可按 90 分钟 / 24 小时 / 7 天 / 30 天查看历史稳定性。"
        },
        {
          "q": "你们和导航站、排行榜有什么不同？",
          "a": "RelayPulse 可以展示赞助信息，但检测方法、质量分和排序不按赞助调整。这个页面公开当前维度、权重和启用状态，便于你判断分数是怎么来的。"
        }
      ]
    }
