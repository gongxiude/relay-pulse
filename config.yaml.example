# RelayPulse 最小配置。启动后所有未列字段使用内置默认值。
#
# 完整字段与调优项（interval / slow_latency / retry / boards / events /
# annotations / storage.postgres / onboarding 等）见 docs/user/config.md
# 可用模板见 templates/ 目录（cc-haiku-arith / cx-codex-arith / gm-flash-arith ...）
#
# new-api 只读审计凭据固定通过环境变量注入：
#   NEWAPI_BASE_URL
#   NEWAPI_ACCESS_TOKEN
#   NEWAPI_USER_ID
# 主动探针如需独立 relay 凭证，可额外提供：
#   NEWAPI_PROBE_ACCESS_TOKEN
#   NEWAPI_PROBE_USER_ID

audit:
  diagnostics:
    enabled: true
    methodology: "quick-probe-v1"
    request_timeout: "60s"
    step_gap_min: "1m"
    step_gap_max: "4m"
    cross_5m_boundary: true
    baseline_enabled: true
    # probe_fallback: 优先 NEWAPI_PROBE_*，缺失时回退 NEWAPI_*
    # probe_only: 只允许 NEWAPI_PROBE_*，缺失则诊断失败
    # newapi_only: 只使用 NEWAPI_* 同步凭证
    credential_mode: "probe_fallback"
    # 模板补洞和 quick-probe 请求骨架复用现有 templates/*.json
    template_binding:
      default:
        cc: "cx-gpt-chat-diagnostic"
        cx: "cx-gpt-chat-diagnostic"
        gm: "cx-gpt-chat-diagnostic"
        openai: "cx-gpt-chat-diagnostic"
        anthropic: "cx-gpt-chat-diagnostic-notemp"
        gemini: "cx-gpt-chat-diagnostic"

monitors:
  - provider: "88code"
    service: "cc"              # 服务类型：cc (Claude Code) / cx (Codex) / gm (Gemini)
    channel: "vip3"
    base_url: "https://api.88code.com"
    template: "cc-haiku-arith"
    api_key: "sk-xxxxxxxx"     # 或用环境变量 MONITOR_88CODE_CC_VIP3_API_KEY 注入

  - provider: "google"
    service: "gm"
    channel: "direct"
    base_url: "https://generativelanguage.googleapis.com"
    template: "gm-flash-arith"
    api_key: "AIza..."
